<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexaDev Academy - Scholarship Enrollment</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 900px;
            margin: 30px auto;
            background: #fff;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        h1, h2 {
            text-align: center;
        }

        h2 {
            margin-top: 30px;
            border-bottom: 2px solid #eee;
            padding-bottom: 5px;
        }

        label {
            display: block;
            margin-top: 10px;
            font-weight: bold;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        textarea {
            resize: vertical;
        }

        .row {
            display: flex;
            gap: 15px;
        }

        .row div {
            flex: 1;
        }

        .checkbox-group {
            margin-top: 10px;
        }

        .checkbox-group label {
            font-weight: normal;
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 25px;
            background-color: #0d6efd;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
        }

        button:hover {
            background-color: #0b5ed7;
        }
    </style>
</head>

<body>

<div class="container">
    <h1>NexaDev Academy</h1>
    <p style="text-align:center;">Scholarship Enrollment Form</p>

    <form action="#" method="POST">

        <h2>1. Personal Information</h2>
        <div class="row">
            <div>
                <label>Full Name</label>
                <input type="text" name="fullname" required>
            </div>
            <div>
                <label>Date of Birth</label>
                <input type="date" name="dob" required>
            </div>
        </div>

        <div class="row">
            <div>
                <label>Gender</label>
                <select name="gender">
                    <option>Male</option>
                    <option>Female</option>
                    <option>Other</option>
                </select>
            </div>
            <div>
                <label>Nationality</label>
                <input type="text" name="nationality">
            </div>
        </div>

        <label>Phone Number</label>
        <input type="tel" name="phone">

        <label>Email Address</label>
        <input type="email" name="email" required>

        <label>Home Address</label>
        <textarea name="address"></textarea>

        <h2>2. Academic Information</h2>
        <label>Current School</label>
        <input type="text" name="school">

        <label>Course of Study</label>
        <input type="text" name="course">

        <label>Level</label>
        <input type="text" name="level">

        <label>Student ID</label>
        <input type="text" name="student_id">

        <label>GPA / Results</label>
        <input type="text" name="gpa">

        <h2>3. Financial Information</h2>
        <label>Parent/Guardian Name</label>
        <input type="text" name="guardian">

        <label>Occupation</label>
        <input type="text" name="occupation">

        <label>Annual Income</label>
        <input type="number" name="income">

        <label>Number of Dependents</label>
        <input type="number" name="dependents">

        <h2>4. Supporting Documents</h2>
        <div class="checkbox-group">
            <label><input type="checkbox"> Admission Letter</label>
            <label><input type="checkbox"> Academic Transcript</label>
            <label><input type="checkbox"> ID Card</label>
            <label><input type="checkbox"> Passport Photograph</label>
            <label><input type="checkbox"> Recommendation Letter</label>
        </div>

        <h2>5. Personal Statement</h2>
        <textarea name="statement" rows="5" placeholder="Why do you deserve this scholarship?"></textarea>

        <h2>6. Referee Information</h2>
        <label>Referee Name</label>
        <input type="text" name="referee_name">

        <label>Position</label>
        <input type="text" name="referee_position">

        <label>Contact</label>
        <input type="text" name="referee_contact">

        <h2>7. Declaration</h2>
        <label>
            <input type="checkbox" required> I declare that the information provided is true.
        </label>

        <button type="submit">Enroll</button>

    </form>
</div>

</body>
</html>
